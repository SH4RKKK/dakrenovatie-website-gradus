---
import { publicReviews } from "../data/reviews";
import ReviewModal from "./ReviewModal.astro";

// Single source of truth: approved reviews from /resources/reviews, capped at 10.
const testimonials = publicReviews.slice(0, 10);
---

<section class="bg-neutral-50 py-20">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Klantbeoordelingen</p>
      <h2 class="mt-4 text-3xl sm:text-4xl">Wat onze klanten zeggen</h2>
      <span class="spark-bar mx-auto mt-6"></span>
    </div>

    <div class="relative mx-auto mt-12 max-w-3xl" data-carousel>
      <div class="overflow-hidden">
        <div class="flex transition-transform duration-500 ease-out" data-track>
          {
            testimonials.map((t) => (
              <figure class="w-full shrink-0 px-2 text-center">
                {t.image && (
                  <img
                    src={t.image}
                    alt=""
                    loading="lazy"
                    class="mx-auto mb-6 h-48 w-full max-w-md rounded-xl object-cover shadow-sm"
                  />
                )}
                <blockquote class="text-lg italic leading-relaxed text-heading">
                  “{t.quote}”
                </blockquote>
                <figcaption class="mt-6 font-display text-lg font-bold text-heading">
                  {t.name}
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>

      <div class="mt-8 flex items-center justify-center gap-2.5" data-dots>
        {
          testimonials.map((_, i) => (
            <button
              type="button"
              class="h-3 w-3 rounded-full bg-accent/30 transition data-[active]:bg-accent"
              data-dot={i}
              aria-label={`Beoordeling ${i + 1}`}
            />
          ))
        }
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <button type="button" data-open-review class="btn-primary w-full sm:w-auto">
        Schrijf een review
      </button>
      <a href="/beoordelingen" class="btn-ghost w-full sm:w-auto">Meer reviews</a>
    </div>
  </div>

  <ReviewModal />
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>("[data-track]");
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dot]"));
    if (!track) return;
    let index = 0;
    const count = dots.length;

    const render = () => {
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, i) =>
        i === index ? d.setAttribute("data-active", "") : d.removeAttribute("data-active")
      );
    };

    dots.forEach((d, i) =>
      d.addEventListener("click", () => {
        index = i;
        render();
        restart();
      })
    );

    let timer: number;
    const restart = () => {
      clearInterval(timer);
      timer = window.setInterval(() => {
        index = (index + 1) % count;
        render();
      }, 3500);
    };

    render();
    restart();
  });
</script>
