---
import { features } from "../data/content";
import Icon from "./Icon.astro";
---

<section class="bg-ink py-20 text-white">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">Waarom Dakrenovatie Midden-Nederland</p>
      <h2 class="mt-4 text-3xl text-white sm:text-4xl">
        Vakwerk waar u op kunt bouwen
      </h2>
    </div>

    <div class="mt-14 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="flex flex-col items-center text-center">
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-accent text-white">
              <Icon name={f.icon} size={34} />
            </div>
            <h3 class="mt-6 text-xl text-white">{f.title}</h3>
            <p class="mt-3 max-w-xs text-sm leading-relaxed text-white/70">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
