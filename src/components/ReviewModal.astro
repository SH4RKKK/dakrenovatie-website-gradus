---
import Icon from "./Icon.astro";
---

<!--
  Reusable "schrijf een review" modal. Drop <ReviewModal /> once on a page;
  any button with a `data-open-review` attribute opens it. The form POSTs to
  /api/review, which emails a plain-text summary plus a ready-to-save JSON block
  the owner drops into /resources/reviews/text to approve.
-->
<dialog
  id="review-dialog"
  class="m-auto max-h-[90vh] w-[92%] max-w-lg overflow-y-auto rounded-2xl border border-black/5 p-0 shadow-card backdrop:bg-black/50"
  aria-labelledby="review-title"
>
  <div class="flex items-center justify-between bg-accent px-6 py-4 text-white">
    <p id="review-title" class="font-display text-sm font-bold uppercase tracking-widest">
      Schrijf een recensie
    </p>
    <button
      type="button"
      id="review-close"
      class="flex h-9 w-9 items-center justify-center rounded-full bg-white/15 transition hover:bg-white/25"
      aria-label="Sluiten"
    >
      <Icon name="close" size={20} />
    </button>
  </div>

  <div class="bg-white px-6 py-6">
    <p class="mb-5 text-sm leading-relaxed">
      Deel uw ervaring met ons. Uw e-mailadres en postcode worden niet op de
      site getoond, we gebruiken ze alleen om uw recensie te verifiëren.
    </p>

    <form id="review-form" class="grid gap-5" novalidate>
      <div>
        <label for="rev-naam" class="mb-1.5 block text-sm font-semibold text-heading"
          >Naam</label
        >
        <input
          id="rev-naam"
          name="naam"
          type="text"
          maxlength="120"
          class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20"
        />
      </div>
      <div>
        <label for="rev-email" class="mb-1.5 block text-sm font-semibold text-heading">
          Email <span class="text-accent">(Vereist)</span>
        </label>
        <input
          id="rev-email"
          name="email"
          type="email"
          required
          maxlength="150"
          class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20 aria-[invalid]:border-red-500"
        />
      </div>
      <div>
        <label for="rev-postcode" class="mb-1.5 block text-sm font-semibold text-heading">
          Postcode <span class="text-accent">(Vereist)</span>
        </label>
        <input
          id="rev-postcode"
          name="postcode"
          type="text"
          required
          maxlength="16"
          class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20 aria-[invalid]:border-red-500"
        />
      </div>
      <div>
        <label for="rev-bericht" class="mb-1.5 block text-sm font-semibold text-heading">
          Uw beoordeling <span class="text-accent">(Vereist)</span>
        </label>
        <textarea
          id="rev-bericht"
          name="review"
          rows="4"
          required
          maxlength="1000"
          class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20 aria-[invalid]:border-red-500"
        ></textarea>
        <p id="rev-bericht-count" class="mt-1 text-right text-xs text-body" aria-live="polite">
          0 / 1000
        </p>
      </div>
      <label class="flex items-start gap-3 text-sm text-heading">
        <input
          id="rev-anon"
          name="anonymous"
          type="checkbox"
          class="mt-0.5 h-4 w-4 accent-accent"
        />
        <span>Toon mijn naam niet op de site (weergeven als "Anonieme klant").</span>
      </label>
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />
      <div>
        <button type="submit" class="btn-primary w-full sm:w-auto">Verstuur recensie</button>
        <p id="review-error" role="alert" class="mt-3 hidden text-sm text-red-600"></p>
      </div>
    </form>
  </div>
</dialog>

<script>
  import { isValidEmail, submitForm, showFieldError, clearFieldErrors } from "../scripts/forms";

  const dialog = document.getElementById("review-dialog") as HTMLDialogElement | null;
  const form = document.getElementById("review-form") as HTMLFormElement | null;
  const errEl = document.getElementById("review-error");
  const closeBtn = document.getElementById("review-close");
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const emailEl = document.getElementById("rev-email");
  const postcodeEl = document.getElementById("rev-postcode");
  const reviewEl = document.getElementById("rev-bericht") as HTMLTextAreaElement | null;
  const fields = [emailEl, postcodeEl, reviewEl];

  // Live character counter for the review box, driven by its own maxlength.
  const reviewCount = document.getElementById("rev-bericht-count");
  if (reviewEl && reviewCount) {
    const max = reviewEl.maxLength;
    const update = () => (reviewCount.textContent = `${reviewEl.value.length} / ${max}`);
    reviewEl.addEventListener("input", update);
    update();
  }

  // Remember what opened the dialog so focus can return there on close (a11y).
  let lastFocused: HTMLElement | null = null;

  document.querySelectorAll<HTMLElement>("[data-open-review]").forEach((btn) =>
    btn.addEventListener("click", () => {
      lastFocused = btn;
      clearFieldErrors(errEl, fields);
      dialog?.showModal();
    })
  );

  const close = () => dialog?.close();
  closeBtn?.addEventListener("click", close);

  // Restore focus to the trigger whenever the dialog closes (button, Escape,
  // backdrop, or submit).
  dialog?.addEventListener("close", () => lastFocused?.focus());

  // Backdrop click: the inner panel fills the dialog box, so detect clicks that
  // land outside the dialog's rect rather than relying on event.target.
  dialog?.addEventListener("click", (e) => {
    const r = dialog.getBoundingClientRect();
    const outside =
      e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom;
    if (outside) close();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearFieldErrors(errEl, fields);

    const data = new FormData(form);
    const naam = String(data.get("naam") ?? "").trim();
    const emailVal = String(data.get("email") ?? "").trim();
    const postcode = String(data.get("postcode") ?? "").trim();
    const reviewText = String(data.get("review") ?? "").trim();
    const anonymous = data.get("anonymous") === "on";

    if (!isValidEmail(emailVal)) {
      showFieldError(errEl, emailEl, "Vul een geldig e-mailadres in.");
      return;
    }
    if (!postcode) {
      showFieldError(errEl, postcodeEl, "Vul uw postcode in.");
      return;
    }
    if (!reviewText) {
      showFieldError(errEl, reviewEl, "Schrijf uw beoordeling.");
      return;
    }

    const label = submitBtn?.textContent ?? "Verstuur recensie";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Versturen...";
    }

    try {
      await submitForm("/api/review", {
        naam,
        email: emailVal,
        postcode,
        review: reviewText,
        anonymous,
        date: new Date().toISOString().slice(0, 10),
        website: data.get("website") ?? "",
      });
      form.innerHTML =
        '<div class="rounded-md bg-green-50 p-8 text-center"><p class="font-display text-lg font-bold text-heading">Bedankt voor uw recensie!</p><p class="mt-2 text-sm leading-relaxed">We hebben uw beoordeling ontvangen en bekijken deze zo snel mogelijk.</p></div>';
    } catch (err) {
      if (errEl) {
        errEl.textContent = (err as Error).message;
        errEl.classList.remove("hidden");
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = label;
      }
    }
  });
</script>
