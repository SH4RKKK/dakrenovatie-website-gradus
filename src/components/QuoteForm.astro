---
import Icon from "./Icon.astro";
---

<section id="offerte" class="py-20">
  <div class="container-x">
    <div class="mx-auto max-w-3xl overflow-hidden rounded-2xl border border-black/5 shadow-card">
      <div class="flex flex-col items-center bg-accent px-8 py-10 text-center text-white">
        <span class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-white/70">
          <Icon name="users" size={30} />
        </span>
        <p class="mt-4 font-display text-sm font-bold uppercase tracking-widest">
          Offerte aanvragen
        </p>
      </div>

      <div class="bg-white px-6 py-10 sm:px-10">
        <h2 class="text-3xl uppercase sm:text-4xl">Vraag hier uw gratis offerte aan</h2>
        <p class="mt-3 leading-relaxed">
          Laat uw gegevens achter en we nemen zo snel mogelijk contact met u op.
        </p>

        <form id="quote-form" class="mt-8 grid gap-5 sm:grid-cols-2" novalidate>
          <div>
            <label for="voornaam" class="mb-1.5 block text-sm font-semibold text-heading"
              >Voornaam</label
            >
            <input
              id="voornaam"
              name="voornaam"
              type="text"
              maxlength="80"
              class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20"
            />
          </div>
          <div>
            <label for="achternaam" class="mb-1.5 block text-sm font-semibold text-heading"
              >Achternaam</label
            >
            <input
              id="achternaam"
              name="achternaam"
              type="text"
              maxlength="80"
              class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20"
            />
          </div>
          <div>
            <label for="email" class="mb-1.5 block text-sm font-semibold text-heading">
              Email <span class="text-accent">(Vereist)</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              maxlength="150"
              class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20 aria-[invalid]:border-red-500"
            />
          </div>
          <div>
            <label for="telefoon" class="mb-1.5 block text-sm font-semibold text-heading"
              >Telefoonnummer</label
            >
            <input
              id="telefoon"
              name="telefoon"
              type="tel"
              maxlength="40"
              class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20"
            />
          </div>
          <div>
            <label for="postcode" class="mb-1.5 block text-sm font-semibold text-heading">
              Postcode <span class="text-accent">(Vereist)</span>
            </label>
            <input
              id="postcode"
              name="postcode"
              type="text"
              required
              maxlength="16"
              class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20 aria-[invalid]:border-red-500"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="bericht" class="mb-1.5 block text-sm font-semibold text-heading"
              >Uw bericht</label
            >
            <textarea
              id="bericht"
              name="bericht"
              rows="4"
              maxlength="1000"
              class="w-full rounded-md border border-neutral-300 px-4 py-3 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20"
            ></textarea>
            <p id="bericht-count" class="mt-1 text-right text-xs text-body" aria-live="polite">
              0 / 1000
            </p>
          </div>
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            class="hidden"
            aria-hidden="true"
          />
          <div class="sm:col-span-2">
            <button type="submit" class="btn-primary w-full sm:w-auto">Verstuur aanvraag</button>
            <p id="form-error" role="alert" class="mt-3 hidden text-sm text-red-600"></p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Submits the quote form to /api/contact, which emails it over SMTP. Client
  // validation mirrors the server's; the server validates again regardless.
  import { isValidEmail, submitForm, showFieldError, clearFieldErrors } from "../scripts/forms";

  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  const errEl = document.getElementById("form-error");
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  // Live character counter for the message box, driven by the textarea's own
  // maxlength so the limit lives in one place (the markup).
  const berichtEl = document.getElementById("bericht") as HTMLTextAreaElement | null;
  const berichtCount = document.getElementById("bericht-count");
  if (berichtEl && berichtCount) {
    const max = berichtEl.maxLength;
    const update = () => (berichtCount.textContent = `${berichtEl.value.length} / ${max}`);
    berichtEl.addEventListener("input", update);
    update();
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const emailVal = String(data.get("email") ?? "").trim();
    const postcode = String(data.get("postcode") ?? "").trim();
    const emailEl = document.getElementById("email");
    const postcodeEl = document.getElementById("postcode");

    clearFieldErrors(errEl, [emailEl, postcodeEl]);

    if (!isValidEmail(emailVal)) {
      showFieldError(errEl, emailEl, "Vul een geldig e-mailadres in.");
      return;
    }
    if (!postcode) {
      showFieldError(errEl, postcodeEl, "Vul uw postcode in.");
      return;
    }

    const label = btn?.textContent ?? "Verstuur aanvraag";
    if (btn) {
      btn.disabled = true;
      btn.textContent = "Versturen...";
    }

    try {
      await submitForm("/api/contact", {
        voornaam: data.get("voornaam") ?? "",
        achternaam: data.get("achternaam") ?? "",
        email: emailVal,
        telefoon: data.get("telefoon") ?? "",
        postcode,
        bericht: data.get("bericht") ?? "",
        website: data.get("website") ?? "",
      });
      form.innerHTML =
        '<div class="rounded-md bg-green-50 p-8 text-center"><p class="font-display text-lg font-bold text-heading">Bedankt voor uw aanvraag!</p><p class="mt-2 text-sm leading-relaxed">We hebben uw aanvraag ontvangen en nemen zo snel mogelijk contact met u op.</p></div>';
    } catch (err) {
      if (errEl) {
        errEl.textContent = (err as Error).message;
        errEl.classList.remove("hidden");
      }
      if (btn) {
        btn.disabled = false;
        btn.textContent = label;
      }
    }
  });
</script>
