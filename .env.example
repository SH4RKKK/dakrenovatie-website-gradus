# SMTP credentials for the administratie@dakrenovatiemn.nl mailbox.
# Copy this file to ".env" and fill in the real values from your email/hosting
# provider. The .env file is gitignored and must never be committed.

# Mail server hostname (from your provider, e.g. mail.yourprovider.nl)
SMTP_HOST=

# 587 = STARTTLS (most common), 465 = implicit TLS
SMTP_PORT=587
# Set to true ONLY when using port 465
SMTP_SECURE=false

# Mailbox login (usually the full email address) and its password
SMTP_USER=administratie@dakrenovatiemn.nl
SMTP_PASS=

# Optional: where form submissions are delivered (defaults to the address in
# src/data/site.ts when left blank)
MAIL_TO=administratie@dakrenovatiemn.nl
# Optional: the From shown on outgoing mail. Many servers require this to match
# SMTP_USER, so leave blank unless your provider says otherwise.
MAIL_FROM=
