# dependencies
node_modules/

# build output
dist/
.astro/
.output/

# env
.env
.env.*
!.env.example

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# os / editor
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json

# playwright
test-results/
playwright-report/
playwright/.cache/

# screenshot iteration artifacts (visual history; not versioned by default, remove
# this line if you want screenshots committed)
testing-screenshots/

# derived render of the brand flyer (regenerable from the PDF)
flyer_render/

# customer review data (emails/postcodes) — never tracked; lives locally and is
# added/approved by dropping JSON into resources/reviews, then rebuilding.
# The format README carries no customer data, so it is tracked.
resources/reviews/*
!resources/reviews/text
resources/reviews/text/*
!resources/reviews/text/README.md

# design reference screenshots (kept locally, not tracked/shipped)
example_page/

# personal notes / scratch
todo.txt

# claude local (personal) settings
.claude/settings.local.json
